# Public base URL of the deployment (used for canonical/OG metadata).
NEXT_PUBLIC_BASE_URL=https://earthquakes-ultra-production.up.railway.app

# Shared secret for the protected refresh endpoints
# (POST /api/refresh and POST /api/phivolcs). If unset, POSTs are unauthenticated.
SCRAPER_API_KEY=

# Automatic earthquake-data refresh (scheduled in src/instrumentation.ts).
# Runs on server boot and then on an interval; set to 1 to disable.
DATA_REFRESH_DISABLED=
# Minutes between refreshes (minimum 5, default 15).
DATA_REFRESH_MINUTES=15
